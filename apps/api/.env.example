# apps/api/.env.example
# Copy this to .env and fill in your values

# Supabase — Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...        # "anon public" key (NOT service role)

# JWT — generate: openssl rand -base64 64
JWT_SECRET=your-secret-min-32-chars
JWT_REFRESH_SECRET=another-different-secret

# Upstash Redis (optional — rate limiting disabled without it)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Super Admin
SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=strong-password-here

# App
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development